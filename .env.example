# ============================================================
# Variáveis de Ambiente — copie este arquivo para .env.local
# e preencha com seus dados reais.
# NUNCA envie o arquivo .env.local para o Git.
# ============================================================

# --- Formulário de Contato com Resend ---
# Crie conta em https://resend.com e gere uma API Key.
# CONTACT_EMAIL_FROM precisa usar um domínio verificado no Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=antharlison12@gmail.com
CONTACT_EMAIL_FROM=portfolio@seudominio.com

# --- Alternativas externas, caso prefira adaptar o formulário ---
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxxx
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
